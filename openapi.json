{
  "openapi": "3.0.0",
  "info": {
    "title": "NodeJsAWSShop API",
    "version": "1.0.0",
    "description": "API for retrieving, creating and importing products"
  }, 
  "paths": {
    "servers": [
      {
        "url": "https://h13ajex47i.execute-api.us-east-1.amazonaws.com/dev",
        "description": "Product Service"
      }
    ],
    "/products": {
      "get": {
        "summary": "Get all products",
        "operationId": "getProductsList",
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a product",
        "operationId": "createProduct",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProduct"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/products/{productId}": {
      "get": {
        "summary": "Get product by ID",
        "operationId": "getProductsById",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the product"
          }
        ],
        "responses": {
          "200": {
            "description": "Product found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Bad request (missing productId)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
  "/import": {
    "servers": [
      {
        "url": " https://ly92y3u86b.execute-api.us-east-1.amazonaws.com/dev",
        "description": "Import Service"
      }
    ],
    "get": {
      "summary": "Generate signed URL for CSV product import",
      "description": "Returns a signed S3 URL for uploading a CSV file to the uploaded folder.",
      "operationId": "importProductsFile",
      "parameters": [
        {
          "name": "name",
          "in": "query",
          "required": true,
          "description": "CSV file name to upload.",
          "schema": {
            "type": "string",
            "example": "products.csv"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "Signed URL generated successfully",
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
                "example": "https://bucket-name.s3.amazonaws.com/uploaded/products.csv?X-Amz-Algorithm=AWS4-HMAC-SHA256..."
              }
            }
          }
        },
        "400": {
          "description": "File name is missing",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Error"
              }
            }
          }
        },
        "500": {
          "description": "Internal server error",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Error"
              }
            }
          }
        }
      }
    }
  } 
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "19ba3d6a-f8ed-491b-a192-0a33b71b38c4"
          },
          "title": {
            "type": "string",
            "example": "Vintage Camera"
          },
          "description": {
            "type": "string",
            "example": "Classic film camera"
          },
          "price": {
            "type": "number",
            "example": 120
          },
          "count": {
            "type": "number",
            "example": 5
          },
          "image": {
            "type": "string",
            "example": "https://picsum.photos/id/1011/200/300"
          }
        },
        "required": ["id", "title", "price", "count"]
      },
      "CreateProduct": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Vintage Camera"
          },
          "description": {
            "type": "string",
            "example": "Classic film camera"
          },
          "price": {
            "type": "number",
            "example": 120
          },
          "count": {
            "type": "number",
            "example": 5
          },
          "image": {
            "type": "string",
            "example": ""
          }
        },
        "required": ["title", "price", "count"]
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Not Found"
          }
        }
      }
    }
  }
}