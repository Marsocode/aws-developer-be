{
  "compilerOptions": {
    "target": "ES2020",
    "types": ["node"],
    "module": "Node16",
    "moduleResolution": "node16",

    "rootDir": "./nodejs",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "resolveJsonModule": true
  },

  "include": [
    "nodejs/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}